<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules - Android 12+ (API 31+)
  Controls what gets backed up via Google Drive Auto Backup and device-to-device transfer.

  EXCLUDE (never leave the device):
    • suttro_session.xml - EncryptedSharedPreferences holding Supabase auth tokens.
    • WebView cookies / cache / databases - contain live session cookies.

  Everything else (suttro_app_meta with last_page, onboarding flag, theme prefs) is included.
-->
<data-extraction-rules>

    <!-- Cloud backup (Google Drive - Auto Backup) -->
    <cloud-backup>
        <exclude domain="sharedpref" path="suttro_session.xml" />
        <exclude domain="file" path="cookies" />
        <exclude domain="file" path="webview" />
        <exclude domain="database" path="webview.db" />
        <exclude domain="database" path="webviewCookiesChromium.db" />
    </cloud-backup>

    <!-- Device-to-device transfer (new phone migration) -->
    <device-transfer>
        <exclude domain="sharedpref" path="suttro_session.xml" />
        <exclude domain="file" path="cookies" />
        <exclude domain="file" path="webview" />
        <exclude domain="database" path="webview.db" />
        <exclude domain="database" path="webviewCookiesChromium.db" />
    </device-transfer>

</data-extraction-rules>
